```yaml
project_map:
  identity:
    name: string
    stack: [primary, secondary]
    paradigm: monolith | modular-monolith | microservices | serverless | library | cli
    maturity: incubation | growth | mature | legacy

  dimensions:
    size: micro | small | medium | large | enterprise
